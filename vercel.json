{
  "version": 2,
  "builds": [
    {
      "src": "api/index.mjs",
      "use": "@vercel/node"
    },
    {
      "src": "web/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.mjs"
    },
    {
      "source": "/web/(.*)",
      "destination": "/web/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/web/index.html"
    }
  ]
}
